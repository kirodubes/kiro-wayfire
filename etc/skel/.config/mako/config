# mako notifications — Tokyo Night defaults.
# The colour lines (background/text/border) are rewritten at login by
# ~/.config/wayfire/scripts/set-theme.sh (pywal) and reloaded with `makoctl reload`.
font=JetBrainsMono Nerd Font 10
background-color=#1a1b26
text-color=#c0caf5
border-color=#7aa2f7
border-size=2
border-radius=8
padding=10
margin=8
default-timeout=5000
anchor=top-right

[urgency=critical]
border-color=#f7768e
default-timeout=0
